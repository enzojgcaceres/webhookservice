# Intercom
INTERCOM_TOKEN=tu_token_de_intercom_aqui
INTERCOM_ADMIN_ID=0000000

# Servidor local
PORT=3000

# Zendesk (opcional)
# Si se setea, el endpoint /zendesk-reply valida la firma HMAC-SHA256
# que Zendesk envía en el header x-zendesk-webhook-signature.
# Si se deja vacío o sin definir, la validación se salta (modo dev).
ZENDESK_WEBHOOK_SECRET=
